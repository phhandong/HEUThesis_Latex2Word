# =============================================================
#                 LaTeX Makefile
# =============================================================
# Usage:
#   make           - 脥锚脠芦卤脿脪毛
#   make clean     - 脟氓脌铆赂篓脰煤脦脛录镁
#   make cleanall  - 脟氓脌铆PDF录掳脣霉脫脨赂篓脰煤脦脛录镁
#   make build     - 卤脿脪毛虏垄脟氓脌铆赂篓脰煤脦脛录镁
#   make rebuild   - 脰脴脨脗卤脿脪毛虏垄脟氓脌铆赂篓脰煤脦脛录镁
#   make help      - 脧脭脢戮掳茂脰煤
# =============================================================

# 露篓脪氓卤脿脪毛脝梅录掳卤脿脪毛虏脦脢媒
TEXCMD = xelatex -interaction=nonstopmode -halt-on-error
BIBCMD = bibtex

# 露篓脪氓脨猫脪陋脟氓脌铆碌脛赂篓脰煤脦脛录镁脌漏脮鹿脙没
AUX_FILES = *.acn *.acr *.alg *.aux *.bak *.bbl *.bcf *.blg *.brf *.cut *.dvi *.exa *.fen *.fls *.glg *.glo *.gls *.ilg *.ind *.ist *.lof *.log *.lot *.nav *.snm *.out *.thm *.ten *.loa *.toc *.toe *.vrb *.xdv *.fdb_latexmk *.run.xml *.synctex.gz

# 露篓脪氓脜脜鲁媒碌脛脛驴脗录(驴脡脩隆)
EXCLUDE_DIRS = .git/

# 禄帽脠隆碌卤脟掳脛驴脗录脧脗脣霉脫脨 .tex 脦脛录镁拢篓脜脜鲁媒麓酶驴脮赂帽碌脛脦脛录镁脙没拢漏
SPINE     = spine
COVER     = a3cover
TARGET    = thesis
MAIN_TEX  = main
MAIN_PDF  = $(MAIN_TEX).pdf
TEX_FILES = $(wildcard *.tex) $(wildcard back/*.tex) $(wildcard body/*.tex) $(wildcard front/*.tex)
BIB_FILES = $(wildcard *.bib)

# 脛卢脠脧脛驴卤锚拢潞卤脿脪毛脣霉脫脨 .tex 脦脛录镁
all:  $(TARGET)
	@echo "卤脿脪毛脥锚鲁脡拢隆"

# 脛拢脢陆鹿忙脭貌拢潞xeLaTeX 隆煤 BibTeX 隆煤 xeLaTeX 隆煤 xeLaTeX
 $(TARGET): $(TEX_FILES) $(BIB_FILES)
	@echo "脮媒脭脷陆酶脨脨碌脷脪禄卤茅卤脿脪毛..."
	$(TEXCMD) $(MAIN_TEX)
	@echo "脮媒脭脷陆酶脨脨虏脦驴录脦脛脧脳卤脿脪毛..."
	$(BIBCMD) $(MAIN_TEX)
	@echo "脮媒脭脷陆酶脨脨碌脷露镁麓脦卤脿脪毛脠路卤拢拢卢陆禄虏忙脪媒脫脙脮媒脠路..."
	$(TEXCMD) $(MAIN_TEX)
	@echo "脮媒脭脷陆酶脨脨碌脷脠媒麓脦卤脿脪毛拢卢脠路卤拢脣霉脫脨脪媒脫脙脦脠露篓..."
	$(TEXCMD) $(MAIN_TEX)
	@echo "脮媒脭脷脡煤鲁脡脛驴卤锚脦脛录镁..."
	$(TEXCMD) $(SPINE)
	$(TEXCMD) $(COVER)
	$(TEXCMD) $(TARGET)

# 脟氓脌铆脣霉脫脨赂篓脰煤脦脛录镁
clean:
	@echo "脮媒脭脷脟氓脌铆赂篓脰煤脦脛录镁..."
	@for pattern in $(AUX_FILES); do \
		#@echo "脮媒脭脷脡戮鲁媒 $$pattern 脦脛录镁:"; \
		find . -type f -name "$$pattern" ! -path "./$(EXCLUDE_DIRS)/*" -print -delete || true; \
	done
	@echo "脟氓脌铆脥锚鲁脡拢隆"

# 脟氓脌铆PDF录掳脣霉脫脨赂篓脰煤脦脛录镁
cleanall: 
	@echo "脮媒脭脷脟氓脌铆脦脛录镁..."
	@for pattern in $(AUX_FILES); do \
		#@echo "脮媒脭脷脡戮鲁媒 $$pattern 脦脛录镁:"; \
		find . -type f -name "$$pattern" ! -path "./$(EXCLUDE_DIRS)/*" -print -delete || true; \
	done
	@rm -f $(MAIN_PDF)
	@rm -f $(SPINE).pdf
	@rm -f $(COVER).pdf
	@rm -f $(TARGET).pdf
	@echo "脟氓脌铆脥锚鲁脡拢隆"

# 卤脿脪毛虏垄脟氓脌铆拢篓鲁拢脫脙脛驴卤锚拢漏
build: all clean

# 脰脴脨脗卤脿脪毛虏垄脟氓脌铆
rebuild: cleanall all clean

help:
	@echo "Usage:"
	@echo "make          - 脥锚脠芦卤脿脪毛"
	@echo "make clean    - 脟氓脌铆赂篓脰煤脦脛录镁"
	@echo "make cleanall - 脟氓脌铆PDF录掳脣霉脫脨赂篓脰煤脦脛录镁"
	@echo "make build    - 卤脿脪毛虏垄脟氓脌铆赂篓脰煤脦脛录镁"
	@echo "make rebuild  - 脰脴脨脗卤脿脪毛虏垄脟氓脌铆赂篓脰煤脦脛录镁"
	@echo "make help     - 脧脭脢戮掳茂脰煤"
	
.PHONY: all clean cleanall build rebuild 
